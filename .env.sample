# Azure AI Foundry project endpoint
# Format: https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
AI_PROJECT_ENDPOINT=https://<your-resource>.services.ai.azure.com/api/projects/<your-project>
AI_PROJECT_KEY=your_project_key_here

# Azure AI Agent workflow name and version
WORKFLOW_NAME=JiraTicketClassifierWorkflow
WORKFLOW_VERSION=1
